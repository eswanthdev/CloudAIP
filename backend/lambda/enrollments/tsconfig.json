{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "/opt/nodejs/src/*": ["../../layers/common/nodejs/src/*"]
    }
  },
  "include": ["index.ts", "handlers/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
